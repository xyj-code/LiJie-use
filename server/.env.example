# 复制此文件为 .env 并按实际情况修改
# 命令: cp .env.example .env （Linux/Mac）或 copy .env.example .env （Windows）

# ==================== 服务器配置 ====================
PORT=3000
NODE_ENV=development

# ==================== MongoDB配置 ====================
MONGODB_URI=mongodb://127.0.0.1:27017/rescue_mesh

# ==================== CORS跨域配置 ====================
CORS_ORIGIN=*

# ==================== 高德地图API（必需）====================
# 用途：逆地理编码 + 路径规划
# 获取地址: https://lbs.amap.com/api/webservice/guide/create-project/get-key
AMAP_API_KEY=your_amap_api_key_here

# ==================== 百度地图AK（可选备用）==================
# 用途：当高德API失败时的备选方案
# 获取地址: https://lbsyun.baidu.com/apiconsole/key#/home
BAIDU_MAP_AK=your_baidu_map_ak_here

# ==================== Redis缓存（可选，性能优化）============= 
# 用途：缓存地理编码和路径规划结果，减少API调用次数
# 如果不配置则使用内存缓存（重启后失效）
# REDIS_URL=redis://localhost:6379

# ==================== DashScope LLM API Key ================
# 用途：AI智能问答 + 生成救援建议
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your_dashscope_key_here
LLM_MODEL=qwen-plus

# ==================== 调试模式 ===========================
DEBUG=true
