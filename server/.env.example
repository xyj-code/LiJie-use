# 复制此文件为 .env 并按实际情况修改

# 服务监听端口
PORT=3000

# MongoDB 连接串
MONGO_URI=mongodb://127.0.0.1:27017/rescue_mesh

# 允许跨域的前端地址（生产环境请改为实际大屏地址，如 http://192.168.1.100:8080）
CORS_ORIGIN=*

# 阿里云百炼（DashScope）API Key — 用于 LLM 智能分析
# 获取方式：https://bailian.console.aliyun.com/
# 模型选择：qwen-plus（推荐）/ qwen-max / qwen-turbo
DASHSCOPE_API_KEY=sk-your-api-key-here
LLM_MODEL=qwen-plus
